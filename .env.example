# TallyPrime connection
TALLYBRIDGE_TALLY_HOST=localhost
TALLYBRIDGE_TALLY_PORT=9000
TALLYBRIDGE_TALLY_COMPANY=
TALLYBRIDGE_TALLY_ENCODING=utf-8
TALLYBRIDGE_TALLY_EXPORT_FORMAT=auto

# Local database
TALLYBRIDGE_DB_PATH=tallybridge.duckdb

# Sync settings
TALLYBRIDGE_SYNC_FREQUENCY_MINUTES=5
TALLYBRIDGE_VOUCHER_BATCH_SIZE=5000

# Performance
TALLYBRIDGE_QUERY_CACHE_TTL=300
TALLYBRIDGE_SLOW_QUERY_THRESHOLD=1.0
TALLYBRIDGE_EXPORT_CHUNK_SIZE=5000

# Write-back (disabled by default)
TALLYBRIDGE_ALLOW_WRITES=false
TALLYBRIDGE_STRICT_STATUS=false

# MCP server (for HTTP transport)
TALLYBRIDGE_MCP_API_KEY=

# Logging
TALLYBRIDGE_LOG_LEVEL=INFO

# Cloud sync (future feature)
# TALLYBRIDGE_SUPABASE_URL=
# TALLYBRIDGE_SUPABASE_KEY=
